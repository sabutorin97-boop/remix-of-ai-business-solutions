# AI-чат-виджет «Макс» (kie.ai)
KIE_API_KEY=

# Порт (Timeweb Cloud Apps пробрасывает свой)
PORT=3000

# Опционально — Яндекс.Метрика (нужна ещё и на этапе сборки, VITE_*)
VITE_YANDEX_METRIKA_ID=

# Telegram-бот, принимающий заявки с сайта
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
# api.telegram.org недоступен напрямую с IP Timeweb App Platform (сетевой
# блок). Указать URL Cloudflare Worker-релея, если задеплоен, иначе не
# заполнять — тогда используется https://api.telegram.org.
TELEGRAM_API_BASE=

# Хранилище заявок — Timeweb S3 (приватный бакет, данные физически в РФ)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# /admin — простой логин/пароль
SITE_BASE_URL=
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
